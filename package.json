{
  "name": "limitless",
  "version": "0.1.0",
  "description": "Keep a Claude Code task running across usage-limit windows.",
  "type": "module",
  "bin": { "limitless": "./dist/cli.js" },
  "engines": { "node": ">=20" },
  "files": ["dist", "scripts/postinstall.mjs"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": { "commander": "^12.1.0", "node-pty": "^1.1.0" },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
